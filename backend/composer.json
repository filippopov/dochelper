{
  "name": "dochelper/backend",
  "type": "project",
  "description": "Dochelper backend API with Symfony 7.4",
  "require": {
    "php": "^8.3",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "symfony/console": "7.4.*",
    "symfony/dotenv": "7.4.*",
    "symfony/flex": "^2",
    "symfony/framework-bundle": "7.4.*",
    "symfony/runtime": "7.4.*",
    "symfony/yaml": "7.4.*"
  },
  "require-dev": {
    "phpunit/phpunit": "12.5.*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
